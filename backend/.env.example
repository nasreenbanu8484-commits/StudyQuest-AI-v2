# StudyQuest AI Backend Production Environment Variables

# 1. API Credentials (Optional: Fallback Mode activated if empty)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. GCP Project Configurations (Only needed when running on GCP Cloud Run)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# 3. Database Location Configuration
# Set custom folder path for SQLite database file
DATABASE_PATH=studyquest.db

# 4. CORS Allowed Web Origins
ALLOW_ORIGINS=http://localhost:3000

# 5. FastMCP Server Options
# Set 'local' or 'remote' (defaults to local direct execution stubs if offline)
MCP_MODE=local
PORT=8000
